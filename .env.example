# ═══════════════════════════════════════════════════════════════
#  Gobi Replica v2 — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── Agent Identity ──────────────────────────────────────────────
AGENT_NAME=Patrick
AGENT_ROLE=Autonomous AI Agent

# ─── Multi-Provider LLM ──────────────────────────────────────────
# Priority order: openrouter > ollama > openai (comma-separated)
LLM_PROVIDERS=openrouter,ollama,openai
LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# OpenRouter (free tier — unlimited tokens on free models)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODELS=meta-llama/llama-3.2-3b-instruct:free,google/gemma-2-9b-it:free
OPENROUTER_HTTP_REFERER=https://github.com/gobi-replica
OPENROUTER_APP_TITLE=Gobi Replica

# Ollama (local — fully offline, no API key)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# OpenAI (paid fallback)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ─── Web Server ──────────────────────────────────────────────────
PORT=8080
SESSION_SECRET=change-this-to-a-random-string

# ─── Email (SMTP Outbound) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=agent@yourdomain.com

# ─── Twilio SMS Gateway ──────────────────────────────────────────
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
SMS_WEBHOOK_PATH=/api/sms/webhook

# ─── Memory & Context ────────────────────────────────────────────
MEMORY_MAX_TURNS=50
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIM=1536
MEMORY_SEMANTIC_THRESHOLD=0.7
MEMORY_SUMMARIZE_AFTER=20

# ─── Persistent Storage ──────────────────────────────────────────
DATA_DIR=./data

# ─── Bright Data (Optional — proxy for scraping/search) ──────────
# BRIGHTDATA_PROXY=http://user:pass@brd.superproxy.io:22225
# BRIGHTDATA_API_TOKEN=your-token
